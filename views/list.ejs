<%- include('includes/_header') %>

<label for="buscar">Buscar</label>
<input type="text" id="buscar" class="input is-primary" placeholder="Moder...">
<br><br>

<% for (let permiso of permisos) { %>
    <% if (permiso.nombre_privilegio == 'crear_personajes') { %>
        <a class="button is-primary" href="/personajes/new">Nuevo personaje</a>
    <% } %>
<% } %>

        <div id="lista">

            <div class="columns">

            <% if(personajes.length == 0) { %>
                <div class="column">
                    No hay personajes registrados.
                </div>
            <% } else { %>

                <% for (let personaje of personajes) { %>

                    <div class="column">
                        <a href="/personajes/<%= personaje.id %>"><%= personaje.nombre %></a>
                        <figure class="image">
                            <img class="is-rounded" src="<%= personaje.imagen %>" />
                        </figure>
                        <a class="button is-primary" href="/personajes/<%= personaje.id %>/edit">
                            <span>Editar</span>
                        </a>
                    </div>
                        
                <% } %>
                
            <% } %>

            </div>
        </div>
    </div>
</section>

<script>
    const buscar = document.getElementById("buscar");
    buscar.onkeyup = () => {
        console.log(buscar.value);
        fetch(`/personajes/buscar/${buscar.value}`, {
            method: 'GET',
        }).then((result) => {
            return result.json();
        }).then((data) => {
            console.log(data);
            let html = '<div class="columns">';

            if(data.personajes.length == 0) { 
                html += `<div class="column">
                    No hay personajes registrados.
                </div>`;
            } else { 

                for (let personaje of data.personajes) { 
                    html += `<div class="column">
                        <a href="/personajes/${personaje.id}">${personaje.nombre}</a>
                        <figure class="image">
                            <img class="is-rounded" src="${personaje.imagen}" />
                        </figure>
                        <a class="button is-primary" href="/personajes/${personaje.id}/edit">
                            <span>Editar</span>
                        </a>
                    </div>`;       
                }
                
            }

            html += `</div>`;

            const lista = document.getElementById("lista");
            lista.innerHTML = html;
        }).catch((error) => {
            console.log(error);
        });
    }
</script>

<%- include('includes/_footer') %>